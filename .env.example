# ExD Accelerator MCP — environment template.
# Copy to .env and fill in for local stdio use (Claude Desktop, smoke tests).
# For Vercel deployment: do NOT set these in Vercel — coworkers pass them as
# HTTP headers when connecting their MCP client.

# Adobe Developer Console — OAuth Server-to-Server credential
CLIENT_ID=
CLIENT_SECRET=

# Adobe org and target sandbox
ORG_ID=
SANDBOX_NAME=
TENANT_ID=

# Decisioning schema for the sandbox (look these up in AJO / Schema Registry)
DECISIONING_SCHEMA_URI=
DECISIONING_SCHEMA_ALT_ID=

# Item catalog for the sandbox
ITEM_CATALOG_ID=

# Optional — override only if you know what you're doing
# OOB_OFFER_CLASS=https://ns.adobe.com/experience/decisioning/offeritem

# Optional — if you want to short-circuit token minting (e.g. pasting a token
# from Postman). Leave blank to let the server auto-mint from CLIENT_ID/SECRET.
# ACCESS_TOKEN=

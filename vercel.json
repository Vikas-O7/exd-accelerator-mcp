{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "api/mcp.js",    "use": "@vercel/node" },
    { "src": "api/health.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/health(/.*)?", "dest": "/api/health.js" },
    { "src": "/api/mcp(/.*)?",    "dest": "/api/mcp.js" },
    { "src": "/health",           "dest": "/api/health.js" }
  ]
}
